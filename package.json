	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"engines": {
		"node": ">=20"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["esbuild", "workerd", "sharp"]
	}
}
